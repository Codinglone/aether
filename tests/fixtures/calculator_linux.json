{
  "name": "Calculator: 2 + 2",
  "platform": "linux",
  "app": "gnome-calculator",
  "initial_state": {
    "screen_size": [1920, 1080],
    "elements": [
      {
        "id": "win1",
        "role": "frame",
        "name": "Calculator",
        "bounds": {"x": 100, "y": 100, "width": 300, "height": 400},
        "state": ["active"],
        "children": [
          {
            "id": "display",
            "role": "text",
